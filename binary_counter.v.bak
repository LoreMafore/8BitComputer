module binary_counter(
    input clk,
    inout [7:0] bus,
    input wire counter_enable,
    input wire counter_out,
    input wire counter_in,
    input wire clear,
    input reset,
    output[3:0] leds,
    );

    
    reg [3:0] counter = 4'b1111;
    assign bus = counter_out ? {4'b000, counter} : 8'bz
   
    always@((posedge clk && counter_enable == 1) or posedge reset or posedge clear )
    begin : main_block

        if (reset || clear)
        begin
            counter <= 4'b1111;
        end

        else if(counter_enable)
        begin
            counter <= counter + 1;
        end
    end

    always @(posedge clk)
    begin
        if (counter_in)
        begin
            counter <= bus[3:0];
        end
        else if (counter_out)
        begin
            bus[3:0] <= counter
        end
    end


    always @(*)
    begin 
        leds <= counter
    end

endmodule
